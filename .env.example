# Copy to .env and fill in your values

DATABASE_URL=postgres://postgres:postgres@localhost:5432/payslip_app

JWT_SECRET=replace_with_long_random_secret_at_least_32_chars

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your_app_password
FROM_EMAIL=Payslip App <noreply@company.com>
SMTP_USE_SSL=false
# For local dev without SMTP, set true to log OTP in backend output instead of sending email.
SMTP_SKIP=false

OTP_TTL_SECS=300
